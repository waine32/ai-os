            safe)   SHELL_AUTO_APPROVE="safe"; printf 'Auto mode: SAFE  (read-only príkazy auto, write/exec vyžadujú potvrdenie)\n' ;;
            off|"") SHELL_AUTO_APPROVE="";    printf 'Auto mode: OFF  (každý príkaz vyžaduje potvrdenie)\n' ;;
            *)      printf 'Použitie: /auto [on|safe|off]\n' ;;
          esac
          ;;
        /help)
          printf '!<príkaz>        spustí shell príkaz priamo — model obídený, tokeny ušetrené\n'
          printf '/status          model, teplota, správy, tokeny, pamäť\n'
          printf '/reset           vymaže históriu aktuálnej konverzácie\n'
          printf '/compact         komprimuje konverzáciu (zachová kontext)\n'
          printf '/plan            ďalšia správa = výstup ako plán (nie implementácia)\n'
          printf '/plan save [p]   uloží posledný plán do súboru a nastaví ako aktívny\n'
          printf '/plan load <p>   načíta existujúci plán ako aktívny kontext\n'
          printf '/plan clear      zruší aktívny plán\n'
          printf '/plan show       zobrazí aktívny plán\n'
          printf '/plan progress [%%]  zobrazí/nastaví percento dokončenia plánu\n'
          printf '/plan history    zobrazí históriu verzií plánov\n'
          printf '/plan continue   pokračuje v aktívnom pláne (vloží ho do promptu)\n'
          printf '/batch <súbor>   spustí prompty zo súboru sekvenčne\n'
          printf '/save [meno]     uloží konverzáciu do named session\n'
          printf '/load [meno]     načíta named session\n'
          printf '/model [flash|pro]  prepne model\n'
          printf '/auto [on|safe|off]  approval loop: on=vždy auto, safe=read-only auto, off=vždy pýtaj\n'
          printf '/memory          zobrazí všetky kontext vrstvy (globálne + workspace + projekt)\n'
          printf '/memory edit [kľúč]  otvorí súbor v editore  (instructions|memory|context|ws|proj)\n'
          printf '/memory add <text>  rýchly zápis do ~/.ai-os/memory.md\n'
          printf '/workspace [cesta]  nastaví Projektovú záložku, vytvorí ds.md + memory/\n'
          printf '/project         info  |  new [názov]  |  list  |  set <cesta>  |  clear\n'
          printf '/clear           vymaže obrazovku\n'
          printf '/help            tento zoznam\n'
          printf '/exit            ukončí session\n'
          printf '\nNástroje modelu: run_shell · read_file · write_file · grep_search · git_info\n'
          ;;
        /exit)
          break
          ;;
        *)
          echo "Neznámy príkaz '${INPUT}'. Napíš /help."
          ;;
      esac
      warp_seq "D;0"
      [[ "$local_skip_api" == true ]] && continue
    fi

    # Apply plan mode prefix if set
    if [[ "$PLAN_MODE" == true ]]; then
      INPUT="Respond with a structured step-by-step plan only. Do not implement anything. Request: ${INPUT}"
      PLAN_MODE=false
    fi

    local_rtctx=$(_runtime_context)
    local_user_msg="$(printf '%s\n\n%s' "$local_rtctx" "$INPUT")"
    CONV=$(jq -n --argjson h "$CONV" --arg c "$local_user_msg" '$h + [{"role":"user","content":$c}]')
    printf '\n'

    _AI_INTERRUPTED=0
    trap '_AI_INTERRUPTED=1' INT
    trap '_AI_INTERRUPTED=1' USR1
    _start_esc_monitor

    _ask_ok=0
    if [[ "$MODEL" == "pro" ]]; then
      run_agentic "$CONV" && _ask_ok=1 || true
    else
      run_interactive_flash "$CONV" && _ask_ok=1 || true
    fi

    _stop_esc_monitor
    trap '' USR1
    trap 'true' INT  # restore — readline needs non-SIG_IGN before next read -er

    if [[ "$_AI_INTERRUPTED" -eq 1 && "$_ask_ok" -eq 0 ]]; then
      printf '\n[prerušené]\n'
      CONV=$(jq '.[:-1]' <<< "$CONV")
      warp_seq "D;1"
      continue
    fi

    if [[ "$_ask_ok" -eq 0 ]]; then
      printf '\nChyba: %s\n' "$(jq -r '.error.message // "no output"' "$AI_TMP/last_output.json")" >&2
      warp_seq "D;1"
      continue
    fi

    OUTPUT=$(< "$AI_TMP/last_stream.txt")
    if [[ -z "$OUTPUT" ]]; then
      printf '\nChyba: žiadna odpoveď\n' >&2
      warp_seq "D;1"
      continue
    fi
    warp_seq "D;0"
    CONV=$(jq -n --argjson h "$CONV" --arg c "$OUTPUT" '$h + [{"role":"assistant","content":$c}]')
  done

  history -w
  exit 0
fi

# ── stateless / session mode ──────────────────────────────────────────────────

MESSAGES='[]'
if [[ "$MODE" = "session" ]]; then
  load_session
  MESSAGES="$LOADED_MESSAGES"
fi

MESSAGES=$(jq -n --argjson h "$MESSAGES" --arg c "$PROMPT" '$h + [{"role":"user","content":$c}]')

if [[ "$MODEL" == "pro" ]]; then
  if ! run_agentic "$MESSAGES"; then
    echo "Error: $(jq -r '.error.message // "no output – see ~/.ai-os/tmp/last_output.json"' "$AI_TMP/last_output.json")" >&2
    exit 1
  fi
else
  if ! ask "$MESSAGES" true; then
    echo "Error: $(jq -r '.error.message // "no output – see ~/.ai-os/tmp/last_output.json"' "$AI_TMP/last_output.json")" >&2
    exit 1
  fi
fi

OUTPUT=$(< "$AI_TMP/last_stream.txt")
if [[ -z "$OUTPUT" ]]; then
  echo "Error: no output – see ~/.ai-os/tmp/last_output.json" >&2
  exit 1
fi

if [[ "$MODE" = "session" ]]; then
  save_session "$PROMPT" "$OUTPUT"
fi
