#!/bin/bash

set -euo pipefail
umask 077

if [[ $# -lt 1 ]]; then
  echo "Usage: ai [flash|pro] [--interactive|-i] [--session] \"prompt\"" >&2
  exit 1
fi

MODEL="$1"; shift

MODE="stateless"
if [[ "${1:-}" = "--interactive" || "${1:-}" = "-i" ]]; then
  MODE="interactive"; shift
elif [[ "${1:-}" = "--session" ]]; then
  MODE="session"; shift
fi

if [[ "$MODE" != "interactive" ]]; then
  PROMPT="${*:-}"
  if [[ -z "$PROMPT" && ! -t 0 ]]; then
    PROMPT=$(cat)
  fi
  if [[ -z "$PROMPT" ]]; then
    echo "Error: prompt is required" >&2
    exit 1
  fi
fi

case "$MODEL" in
  flash) MODEL_NAME="deepseek-v4-flash" ;;
  pro)   MODEL_NAME="deepseek-v4-pro" ;;
  *)
    echo "Usage: ai [flash|pro] [--interactive|-i] [--session] \"prompt\"" >&2
    exit 1
    ;;
esac

ENDPOINT="https://api.deepseek.com/chat/completions"
API_KEY="${DEEPSEEK_API_KEY:?DEEPSEEK_API_KEY is not set}"
TEMPERATURE="${AI_TEMPERATURE:-0}"
CONTEXT_LIMIT="${AI_CONTEXT_LIMIT:-6000}"
HIST_FILE="$HOME/.ai-os/sessions/history.json"
AI_TMP="$HOME/.ai-os/tmp"
mkdir -p "$AI_TMP"

# ── context file hierarchy ────────────────────────────────────────────────────

# Auto-create default context files on first run
_init_context_files() {
  local ifile="$HOME/.ai-os/instructions.md"
  local mfile="$HOME/.ai-os/memory.md"
  mkdir -p "$HOME/.ai-os"
  if [[ ! -f "$ifile" ]]; then
    cat > "$ifile" << 'EOF'
## Identity
You are a deterministic CLI assistant.

## Language
Always respond in Slovak language.

## Behavior
Be concise and direct. Prefer structured output for complex answers.
EOF
  fi
  if [[ ! -f "$mfile" ]]; then
    cat > "$mfile" << 'EOF'
# Memory

Add facts, preferences, and ongoing context here.
EOF
  fi
}

# Assemble SYSTEM_PROMPT from layered context files (like Claude Code's CLAUDE.md hierarchy)
_build_system_prompt() {
  local instructions="" memory="" context="" ds_content="" dir
  local -a ds_files
  ds_files=()

  if [[ -f ~/.ai-os/instructions.md ]]; then
    instructions=$(< ~/.ai-os/instructions.md)
  else
    instructions="You are a deterministic CLI assistant. Always respond in Slovak language."
  fi

  [[ -f ~/.ai-os/memory.md  ]] && memory=$(< ~/.ai-os/memory.md)
  [[ -f ~/.ai-os/context.md ]] && context=$(< ~/.ai-os/context.md)
  # backward compat: fall back to legacy global.md
  [[ -z "$context" && -f ~/.ai-os/context/global.md ]] && context=$(< ~/.ai-os/context/global.md)

  # Walk CWD upward collecting ds.md files (parent-first so CWD is most specific)
  dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/ds.md" ]] && ds_files=("$dir/ds.md" "${ds_files[@]+"${ds_files[@]}"}")
    dir=$(dirname "$dir")
  done
  if [[ ${#ds_files[@]} -gt 0 ]]; then
    for f in "${ds_files[@]}"; do
      ds_content+=$'\n\n'"$(< "$f")"
    done
  fi

  local prompt="$instructions"
  [[ -n "$memory"     ]] && prompt+=$'\n\n## Memory\n'"$memory"
  [[ -n "$context"    ]] && prompt+=$'\n\n## Context\n'"$context"
  [[ -n "$ds_content" ]] && prompt+=$'\n\n## Project\n'"$ds_content"
  echo "$prompt"
}

_init_context_files
SYSTEM_PROMPT=$(_build_system_prompt)

LAST_PROMPT_TOKENS=0
LAST_COMPLETION_TOKENS=0

# ── helpers ───────────────────────────────────────────────────────────────────

estimate_tokens() {
  local s="$1"
  echo $(( ${#s} / 4 ))
}

# One-time migration from history.txt → history.json
migrate_history() {
  local txt="$HOME/.ai-os/sessions/history.txt"
  [[ -f "$txt" && ! -f "$HIST_FILE" ]] || return 0
  local arr='[]' line content
  while IFS= read -r line; do
    if [[ "$line" = "USER: "* ]]; then
      content="${line#USER: }"
      arr=$(jq -n --argjson h "$arr" --arg c "$content" '$h + [{"role":"user","content":$c}]')
    elif [[ "$line" = "ASSISTANT: "* ]]; then
      content="${line#ASSISTANT: }"
      arr=$(jq -n --argjson h "$arr" --arg c "$content" '$h + [{"role":"assistant","content":$c}]')
    fi
  done < "$txt"
  echo "$arr" > "$HIST_FILE"
}

# Compress oldest half of turns into a summary; returns new history JSON
compress_history() {
  local history_json="$1"
  local non_summary total half old_turns old_text sum_content sum_msgs summary
  local prev_summarized new_count recent

  non_summary=$(jq '[.[] | select(.role != "summary")]' <<< "$history_json")
  total=$(jq 'length' <<< "$non_summary")
  half=$(( total / 2 ))
  [[ $half -lt 2 ]] && { echo "$history_json"; return; }

  old_turns=$(jq --argjson n "$half" '.[:$n]' <<< "$non_summary")
  old_text=$(jq -r '.[] | "\(.role | ascii_upcase): \(.content)"' <<< "$old_turns")

  sum_content=$(printf 'Summarize the following conversation into one concise paragraph. Preserve all key facts, decisions, code snippets, user preferences, and important context. Output only the summary text with no preamble, labels, or explanation.\n\n%s' "$old_text")
  sum_msgs=$(jq -n --arg c "$sum_content" '[{"role":"user","content":$c}]')

  summary=$(ask "$sum_msgs" 2>/dev/null) || { echo "$history_json"; return; }
  [[ -z "$summary" ]] && { echo "$history_json"; return; }

  prev_summarized=$(jq '[.[] | select(.role=="summary") | .summarized_turns // 0] | add // 0' <<< "$history_json")
  new_count=$(( prev_summarized + half ))
  recent=$(jq --argjson n "$half" '.[$n:]' <<< "$non_summary")

  jq -n \
    --arg s "$summary" \
    --argjson n "$new_count" \
    --argjson r "$recent" \
    '[{"role":"summary","content":$s,"summarized_turns":$n}] + $r'
}

# ── API call ──────────────────────────────────────────────────────────────────

# ask MESSAGES [stream=false]
# stream=false (default): returns content via stdout — use with $()
# stream=true: streams tokens directly to stdout, saves result to $AI_TMP/last_stream.txt — call without $()
ask() {
  local messages="$1" stream="${2:-false}"
  local all_messages payload
  all_messages=$(jq -n \
    --arg    system "$SYSTEM_PROMPT" \
    --argjson msgs   "$messages" \
    '[{"role":"system","content":$system}] + $msgs')
  payload=$(jq -n \
    --arg    model   "$MODEL_NAME" \
    --argjson msgs   "$all_messages" \
    --argjson temp   "$TEMPERATURE" \
    --argjson stream "$stream" \
    '{"model":$model,"messages":$msgs,"temperature":$temp,"stream":$stream}')

  if [[ "$stream" == true ]]; then
    local full_response="" is_sse=false raw_buf="" sse_line chunk token
    while IFS= read -r sse_line; do
      if [[ "$is_sse" == false && "$sse_line" != data:* && -n "$sse_line" ]]; then
        raw_buf+="${sse_line}"$'\n'
      fi
      [[ "$sse_line" = "data: [DONE]" ]] && break
      [[ "$sse_line" = data:* ]] || continue
      is_sse=true
      chunk="${sse_line#data: }"
      token=$(jq -r '.choices[0].delta.content // empty' <<< "$chunk" 2>/dev/null) || continue
      [[ -n "$token" ]] && printf '%s' "$token" && full_response+="$token"
    done < <(curl -sN --no-buffer "$ENDPOINT" \
      -H "Content-Type: application/json" \
      --config <(printf 'header = "Authorization: Bearer %s"\n' "$API_KEY") \
      -d "$payload" || true)

    # Fallback: non-SSE response (mock, error, or older API)
    if [[ "$is_sse" == false && -n "$raw_buf" ]]; then
      printf '%s' "$raw_buf" > "$AI_TMP/last_output.json"
      local fb
      fb=$(jq -r '.choices[0].message.content // empty' "$AI_TMP/last_output.json" 2>/dev/null)
      if [[ -n "$fb" ]]; then
        printf '%s' "$fb"
        full_response="$fb"
      else
        LAST_PROMPT_TOKENS=0; LAST_COMPLETION_TOKENS=0
        return 1
      fi
    fi

    printf '\n'
    printf '%s' "$full_response" > "$AI_TMP/last_stream.txt"
    jq -n --arg c "$full_response" '{"choices":[{"message":{"content":$c}}]}' > "$AI_TMP/last_output.json"
    LAST_PROMPT_TOKENS=0
    LAST_COMPLETION_TOKENS="${#full_response}"
  else
    local response
    response=$(curl -s "$ENDPOINT" \
      -H "Content-Type: application/json" \
      --config <(printf 'header = "Authorization: Bearer %s"\n' "$API_KEY") \
      -d "$payload")
    echo "$response" > "$AI_TMP/last_output.json"
    LAST_PROMPT_TOKENS=$(jq -r '.usage.prompt_tokens // 0' "$AI_TMP/last_output.json")
    LAST_COMPLETION_TOKENS=$(jq -r '.usage.completion_tokens // 0' "$AI_TMP/last_output.json")
    jq -r '.choices[0].message.content // empty' "$AI_TMP/last_output.json"
  fi
}

# ── session helpers ───────────────────────────────────────────────────────────

# Sets global LOADED_MESSAGES and may modify global SYSTEM_PROMPT.
# Must be called as a plain command, not via $(...), to preserve side-effects.
LOADED_MESSAGES='[]'
load_session() {
  migrate_history
  if [[ ! -f "$HIST_FILE" ]]; then
    LOADED_MESSAGES='[]'
    return
  fi

  local hist tokens summary_content
  hist=$(< "$HIST_FILE")
  tokens=$(estimate_tokens "$hist")

  if [[ $tokens -gt $CONTEXT_LIMIT ]]; then
    local compressed
    compressed=$(compress_history "$hist")
    echo "$compressed" > "$HIST_FILE"
    hist="$compressed"
  fi

  summary_content=$(jq -r '[.[] | select(.role=="summary") | .content] | join("\n\n")' <<< "$hist")
  if [[ -n "$summary_content" ]]; then
    SYSTEM_PROMPT="${SYSTEM_PROMPT}

[Zhrnutie predchádzajúcej konverzácie]
${summary_content}"
  fi

  LOADED_MESSAGES=$(jq '[.[] | select(.role != "summary")]' <<< "$hist")
}

save_session() {
  local prompt="$1" output="$2"
  mkdir -p "$(dirname "$HIST_FILE")"
  local current='[]'
  [[ -f "$HIST_FILE" ]] && current=$(< "$HIST_FILE")
  jq -n \
    --argjson h "$current" \
    --arg p "$prompt" \
    --arg o "$output" \
    '$h + [{"role":"user","content":$p},{"role":"assistant","content":$o}]' \
    > "$HIST_FILE"
}

# ── interactive mode ──────────────────────────────────────────────────────────

if [[ "$MODE" = "interactive" ]]; then
  CONV='[]'
  PLAN_MODE=false

  HISTFILE="$HOME/.ai-os/sessions/interactive_history"
  HISTSIZE=500
  HISTFILESIZE=500
  mkdir -p "$(dirname "$HISTFILE")"
  history -r "$HISTFILE" 2>/dev/null || true

  # Warp OSC 133 shell integration
  WARP=""
  [[ "${TERM_PROGRAM:-}" == "WarpTerminal" ]] && WARP=true
  warp_seq() { [[ -n "$WARP" ]] && printf '\033]133;%s\007' "$1"; }

  # Tab completion for slash commands
  __ai_tab() {
    local cmds=("/status" "/reset" "/compact" "/plan" "/batch " "/save " "/load "
                 "/model " "/memory" "/clear" "/help" "/exit")
    local cur="$READLINE_LINE"
    [[ "$cur" != /* ]] && return
    local matches=()
    for c in "${cmds[@]}"; do
      [[ "$c" = "$cur"* ]] && matches+=("$c")
    done
    if [[ ${#matches[@]} -eq 1 ]]; then
      READLINE_LINE="${matches[0]}"
      READLINE_POINT=${#READLINE_LINE}
    elif [[ ${#matches[@]} -gt 1 ]]; then
      printf '\n%s\n' "${matches[*]}"
      READLINE_LINE="$cur"
      READLINE_POINT=${#READLINE_LINE}
    fi
  }
  bind -x '"\t": __ai_tab' 2>/dev/null || true

  echo "AI-OS  •  $MODEL  •  /help pre príkazy  •  Ctrl+C na ukončenie"
  echo "────────────────────────────────────────────────────────────────"
  while true; do
    warp_seq A
    read -er -p $'\n> ' INPUT || break
    warp_seq C
    [[ "$INPUT" = "exit" || "$INPUT" = "quit" || -z "$INPUT" ]] && break

    history -s "$INPUT"

    if [[ "$INPUT" = /* ]]; then
      case "$INPUT" in
        /status)
          MSG_COUNT=$(jq 'length' <<< "$CONV")
          CONV_TOKENS=$(estimate_tokens "$CONV")
          MEM_SIZE=0
          [[ -f ~/.ai-os/memory.md ]] && MEM_SIZE=$(wc -c < ~/.ai-os/memory.md | tr -d ' ')
          printf 'model:              %s\ntemperature:        %s\nmessages:           %s\nestim. tokens:      %s\nprompt_tokens:      %s\ncompletion_tokens:  %s\nmemory:             %s B\n' \
            "$MODEL_NAME" "$TEMPERATURE" "$MSG_COUNT" "$CONV_TOKENS" "$LAST_PROMPT_TOKENS" "$LAST_COMPLETION_TOKENS" "$MEM_SIZE"
          ;;
        /reset)
          CONV='[]'
          echo "História konverzácie vymazaná."
          ;;
        /memory)
          local_shown=0
          for local_f in ~/.ai-os/instructions.md ~/.ai-os/memory.md ~/.ai-os/context.md ~/.ai-os/context/global.md; do
            if [[ -f "$local_f" ]]; then
              printf '\n── %s ──\n' "$local_f"
              cat "$local_f"
              local_shown=1
            fi
          done
          [[ "$local_shown" -eq 0 ]] && echo "(žiadne kontextové súbory nenájdené)"
          ;;
        /clear)
          printf '\033[2J\033[H'
          ;;
        /model*)
          local_m="${INPUT#/model}"
          local_m="${local_m# }"
          case "$local_m" in
            flash) MODEL="flash"; MODEL_NAME="deepseek-v4-flash"; echo "Model prepnutý na: flash" ;;
            pro)   MODEL="pro";   MODEL_NAME="deepseek-v4-pro";   echo "Model prepnutý na: pro" ;;
            "")    echo "Aktuálny model: $MODEL ($MODEL_NAME)" ;;
            *)     echo "Použitie: /model [flash|pro]" ;;
          esac
          ;;
        /compact)
          local_compressed=$(compress_history "$CONV") || { echo "Komprimácia zlyhala."; continue; }
          CONV="$local_compressed"
          echo "Konverzácia komprimovaná. Správy: $(jq 'length' <<< "$CONV")"
          ;;
        /plan)
          PLAN_MODE=true
          echo "Plánovací mód: ďalšia správa bude odoslaná s inštrukciou na vypracovanie plánu."
          ;;
        /batch*)
          local_file="${INPUT#/batch}"
          local_file="${local_file# }"
          if [[ -z "$local_file" || ! -f "$local_file" ]]; then
            echo "Použitie: /batch <súbor>  (každý riadok = jeden prompt)"
          else
            # Security: restrict batch to files within user's home directory
            local_file=$(realpath -m "$local_file" 2>/dev/null || echo "$local_file")
            if [[ "$local_file" != "$HOME"* ]]; then
              echo "Chyba: /batch povolený len v rámci domovského adresára." >&2
            else
              while IFS= read -r local_line; do
                [[ -z "$local_line" || "$local_line" = "#"* ]] && continue
                printf '\n>>> %s\n' "$local_line"
                CONV=$(jq -n --argjson h "$CONV" --arg c "$local_line" '$h + [{"role":"user","content":$c}]')
                printf '\nai: '
                ask "$CONV" true || { echo "Chyba API pri '$local_line'" >&2; continue; }
                local_out=$(< "$AI_TMP/last_stream.txt")
                if [[ -z "$local_out" ]]; then
                  echo "Chyba API pri '$local_line'" >&2
                else
                  CONV=$(jq -n --argjson h "$CONV" --arg c "$local_out" '$h + [{"role":"assistant","content":$c}]')
                fi
              done < "$local_file"
            fi
          fi
          ;;
        /save*)
          local_name="${INPUT#/save}"
          local_name="${local_name# }"
          local_name="${local_name:-default}"
          # Security: strip path traversal characters — allow only [a-zA-Z0-9_-]
          local_name="${local_name//[^a-zA-Z0-9_-]/}"
          [[ -z "$local_name" ]] && local_name="default"
          mkdir -p "$HOME/.ai-os/sessions/named"
          echo "$CONV" > "$HOME/.ai-os/sessions/named/${local_name}.json"
          echo "Session uložená: $local_name"
          ;;
        /load*)
          local_name="${INPUT#/load}"
          local_name="${local_name# }"
          local_name="${local_name:-default}"
          # Security: strip path traversal characters — allow only [a-zA-Z0-9_-]
          local_name="${local_name//[^a-zA-Z0-9_-]/}"
          [[ -z "$local_name" ]] && local_name="default"
          local_f="$HOME/.ai-os/sessions/named/${local_name}.json"
          if [[ -f "$local_f" ]]; then
            CONV=$(< "$local_f")
            echo "Session načítaná: $local_name ($(jq 'length' <<< "$CONV") správ)"
          else
            echo "Session nenájdená: $local_name"
          fi
          ;;
        /help)
          printf '/status          model, teplota, správy, tokeny, pamäť\n'
          printf '/reset           vymaže históriu aktuálnej konverzácie\n'
          printf '/compact         komprimuje konverzáciu (zachová kontext)\n'
          printf '/plan            ďalšia správa = výstup ako plán (nie implementácia)\n'
          printf '/batch <súbor>   spustí prompty zo súboru sekvenčne\n'
          printf '/save [meno]     uloží konverzáciu do named session\n'
          printf '/load [meno]     načíta named session\n'
          printf '/model [flash|pro]  prepne model\n'
          printf '/memory          zobrazí kontextové súbory (instructions, memory, context)\n'
          printf '/clear           vymaže obrazovku\n'
          printf '/help            tento zoznam\n'
          printf '/exit            ukončí session\n'
          ;;
        /exit)
          break
          ;;
        *)
          echo "Neznámy príkaz '${INPUT}'. Napíš /help."
          ;;
      esac
      warp_seq "D;0"
      continue
    fi

    # Apply plan mode prefix if set
    if [[ "$PLAN_MODE" == true ]]; then
      INPUT="Respond with a structured step-by-step plan only. Do not implement anything. Request: ${INPUT}"
      PLAN_MODE=false
    fi

    CONV=$(jq -n --argjson h "$CONV" --arg c "$INPUT" '$h + [{"role":"user","content":$c}]')
    printf '\nai: '
    ask "$CONV" true || {
      printf '\nChyba: %s\n' "$(jq -r '.error.message // "no output"' "$AI_TMP/last_output.json")" >&2
      warp_seq "D;1"
      continue
    }
    OUTPUT=$(< "$AI_TMP/last_stream.txt")
    if [[ -z "$OUTPUT" ]]; then
      printf '\nChyba: žiadna odpoveď\n' >&2
      warp_seq "D;1"
      continue
    fi
    warp_seq "D;0"
    CONV=$(jq -n --argjson h "$CONV" --arg c "$OUTPUT" '$h + [{"role":"assistant","content":$c}]')
  done

  history -w
  exit 0
fi

# ── stateless / session mode ──────────────────────────────────────────────────

MESSAGES='[]'
if [[ "$MODE" = "session" ]]; then
  load_session
  MESSAGES="$LOADED_MESSAGES"
fi

MESSAGES=$(jq -n --argjson h "$MESSAGES" --arg c "$PROMPT" '$h + [{"role":"user","content":$c}]')

if ! ask "$MESSAGES" true; then
  echo "Error: $(jq -r '.error.message // "no output – see ~/.ai-os/tmp/last_output.json"' "$AI_TMP/last_output.json")" >&2
  exit 1
fi

OUTPUT=$(< "$AI_TMP/last_stream.txt")
if [[ -z "$OUTPUT" ]]; then
  echo "Error: no output – see ~/.ai-os/tmp/last_output.json" >&2
  exit 1
fi

if [[ "$MODE" = "session" ]]; then
  save_session "$PROMPT" "$OUTPUT"
fi
