#!/bin/bash

set -euo pipefail
umask 077

if [[ $# -lt 1 ]]; then
  echo "Usage: ai [flash|pro] [--interactive|-i] [--session] \"prompt\"" >&2
  exit 1
fi

MODEL="$1"; shift

MODE="stateless"
if [[ "${1:-}" = "--interactive" || "${1:-}" = "-i" ]]; then
  MODE="interactive"; shift
elif [[ "${1:-}" = "--session" ]]; then
  MODE="session"; shift
fi

if [[ "$MODE" != "interactive" ]]; then
  PROMPT="${*:-}"
  if [[ -z "$PROMPT" && ! -t 0 ]]; then
    PROMPT=$(cat)
  fi
  if [[ -z "$PROMPT" ]]; then
    echo "Error: prompt is required" >&2
    exit 1
  fi
fi

case "$MODEL" in
  flash) MODEL_NAME="deepseek-v4-flash" ;;
  pro)   MODEL_NAME="deepseek-v4-pro" ;;
  *)
    echo "Usage: ai [flash|pro] [--interactive|-i] [--session] \"prompt\"" >&2
    exit 1
    ;;
esac

ENDPOINT="https://api.deepseek.com/chat/completions"
API_KEY="${DEEPSEEK_API_KEY:?DEEPSEEK_API_KEY is not set}"
TEMPERATURE="${AI_TEMPERATURE:-0}"
CONTEXT_LIMIT="${AI_CONTEXT_LIMIT:-6000}"
HIST_FILE="$HOME/.ai-os/sessions/history.json"
AI_TMP="$HOME/.ai-os/tmp"
mkdir -p "$AI_TMP"

FLASH_TOOLS=$(jq -cn '[{
  "type": "function",
  "function": {
    "name": "delegate_to_flash",
    "description": "Delegate a self-contained subtask to the fast Flash model. Use for straightforward lookups, text formatting, drafting, or factual retrieval that does not require deep reasoning. Flash has no conversation history — include all needed context in the prompt.",
    "parameters": {
      "type": "object",
      "properties": {
        "prompt": {"type":"string","description":"Complete, self-contained prompt for Flash. Include all context."},
        "reason": {"type":"string","description":"Why this subtask is delegated to Flash."}
      },
      "required": ["prompt"]
    }
  }
}]')

SHELL_TOOL=$(jq -cn '[{
  "type": "function",
  "function": {
    "name": "run_shell",
    "description": "Execute a shell command on the local machine. Use for file operations, directory listing, running scripts, or any system task. Always prefer minimal, safe commands.",
    "parameters": {
      "type": "object",
      "properties": {
        "command": {"type":"string","description":"Shell command to execute."},
        "reason":  {"type":"string","description":"Why this command is needed."}
      },
      "required": ["command"]
    }
  }
}]')

AGENT_TOOLS=$(jq -cn '[
  {"type":"function","function":{"name":"read_file",
    "description":"Read a file from the filesystem. Pre-approved, no user confirmation needed.",
    "parameters":{"type":"object","properties":{
      "path":   {"type":"string","description":"File path to read"},
      "offset": {"type":"integer","description":"Start line 1-based (default: 1)"},
      "limit":  {"type":"integer","description":"Max lines to return (default: 200)"}
    },"required":["path"]}}},
  {"type":"function","function":{"name":"write_file",
    "description":"Write content to a file. Always asks for user confirmation before writing.",
    "parameters":{"type":"object","properties":{
      "path":    {"type":"string","description":"File path to write"},
      "content": {"type":"string","description":"Complete file content"}
    },"required":["path","content"]}}},
  {"type":"function","function":{"name":"grep_search",
    "description":"Search for a pattern in files. Pre-approved. Returns matching lines with file:line references.",
    "parameters":{"type":"object","properties":{
      "pattern": {"type":"string","description":"Search pattern (regex ok)"},
      "path":    {"type":"string","description":"Directory or file to search (default: .)"},
      "options": {"type":"string","description":"Extra grep flags e.g. -i -l -w"}
    },"required":["pattern"]}}},
  {"type":"function","function":{"name":"git_info",
    "description":"Get git repository information. Pre-approved.",
    "parameters":{"type":"object","properties":{
      "type":{"type":"string","enum":["status","diff","log","branch"],
              "description":"status=short status, diff=unstaged diff, log=recent commits, branch=current branch"}
    },"required":["type"]}}},
  {"type":"function","function":{"name":"save_plan",
    "description":"Persist the current plan to disk so it survives session restarts. Pre-approved — call this immediately after creating or updating a plan. The plan is injected into every future system prompt automatically.",
    "parameters":{"type":"object","properties":{
      "content": {"type":"string","description":"Full plan content in markdown"},
      "name":    {"type":"string","description":"Short slug for the plan file, e.g. 'ci-mvp' or 'refactor' (alphanumeric + hyphens)"}
    },"required":["content","name"]}}}
]')

FLASH_INTERACTIVE_TOOLS=$(jq -cn --argjson a "$SHELL_TOOL" --argjson b "$AGENT_TOOLS" '$a + $b')
PRO_TOOLS=$(jq -cn --argjson a "$FLASH_TOOLS" --argjson b "$SHELL_TOOL" --argjson c "$AGENT_TOOLS" '$a + $b + $c')

# ── context file hierarchy ────────────────────────────────────────────────────

# Auto-create default context files on first run
_init_context_files() {
  local ifile="$HOME/.ai-os/instructions.md"
  local mfile="$HOME/.ai-os/memory.md"
  mkdir -p "$HOME/.ai-os"
  if [[ ! -f "$ifile" ]]; then
    cat > "$ifile" << 'EOF'
## Identity
You are a deterministic CLI assistant.

## Language
Always respond in Slovak language.

## Behavior
Be concise and direct. Prefer structured output for complex answers.

## Model selection

🟣 Pro — use for:
- debugging
- architecture decisions
- flaky tests
- async race conditions
- large refactors

🔵 Flash — use for:
- CRUD tests
- boilerplate generation
- rename/refactor
- generating mocks
- formatting
- repetitive edits

Efficient pattern: analysis (Pro) → implementation (Flash) → final review (Pro)
EOF
  fi
  if [[ ! -f "$mfile" ]]; then
    cat > "$mfile" << 'EOF'
# Memory

Add facts, preferences, and ongoing context here.
EOF
  fi
}

# Assemble SYSTEM_PROMPT from layered context files (like Claude Code's CLAUDE.md hierarchy)
_build_system_prompt() {
  local instructions="" memory="" context="" ds_content="" dir
  local ws_meta="" ws_instr="" ws_mem="" ws_ctx=""
  local -a ds_files
  ds_files=()

  if [[ -f ~/.ai-os/instructions.md ]]; then
    instructions=$(< ~/.ai-os/instructions.md)
  else
    instructions="You are a deterministic CLI assistant. Always respond in Slovak language."
  fi

  [[ -f ~/.ai-os/memory.md  ]] && memory=$(< ~/.ai-os/memory.md)
  [[ -f ~/.ai-os/context.md ]] && context=$(< ~/.ai-os/context.md)
  # backward compat: fall back to legacy global.md
  [[ -z "$context" && -f ~/.ai-os/context/global.md ]] && context=$(< ~/.ai-os/context/global.md)

  # Workspace context layer (between global context and project ds.md)
  if [[ -f ~/.ai-os/workspace ]]; then
    local _ws; _ws=$(< ~/.ai-os/workspace); _ws="${_ws%$'\n'}"
    if [[ -d "$_ws" ]]; then
      [[ -f "$_ws/ds.md"                  ]] && ws_meta=$(< "$_ws/ds.md")
      [[ -f "$_ws/memory/instructions.md" ]] && ws_instr=$(< "$_ws/memory/instructions.md")
      [[ -f "$_ws/memory/memory.md"       ]] && ws_mem=$(< "$_ws/memory/memory.md")
      [[ -f "$_ws/memory/context.md"      ]] && ws_ctx=$(< "$_ws/memory/context.md")
    fi
  fi

  # Walk CWD upward collecting ds.md files (parent-first so CWD is most specific)
  dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    [[ -f "$dir/ds.md" ]] && ds_files=("$dir/ds.md" "${ds_files[@]+"${ds_files[@]}"}")
    dir=$(dirname "$dir")
  done
  # Fallback: load last known project from chpwd shell hook
  if [[ -f ~/.ai-os/current-project ]]; then
    local proj_root
    proj_root=$(< ~/.ai-os/current-project)
    proj_root="${proj_root%$'\n'}"
    if [[ -d "$proj_root" && -f "$proj_root/ds.md" ]]; then
      local already_loaded=0
      if [[ ${#ds_files[@]} -gt 0 ]]; then
        for f in "${ds_files[@]}"; do
          [[ "$f" = "$proj_root/ds.md" ]] && already_loaded=1 && break
        done
      fi
      [[ "$already_loaded" -eq 0 ]] && ds_files=("$proj_root/ds.md" "${ds_files[@]+"${ds_files[@]}"}")
    fi
  fi
  if [[ ${#ds_files[@]} -gt 0 ]]; then
    for f in "${ds_files[@]}"; do
      ds_content+=$'\n\n'"$(< "$f")"
    done
  fi

  # Active plan layer — loaded from ~/.ai-os/current-plan pointer
  local plan_content=""
  if [[ -f ~/.ai-os/current-plan ]]; then
    local _plan_path
    _plan_path=$(< ~/.ai-os/current-plan); _plan_path="${_plan_path%$'\n'}"
    if [[ -f "$_plan_path" && -r "$_plan_path" ]]; then
      local _plan_lines
      _plan_lines=$(wc -l < "$_plan_path" | tr -d ' ')
      if [[ "$_plan_lines" -gt 200 ]]; then
        plan_content=$(head -200 "$_plan_path")$'\n\n[... plán skrátený na 200 riadkov ...]'
      else
        plan_content=$(< "$_plan_path")
      fi
    fi
  fi

  local prompt="$instructions"
  [[ -n "$memory"       ]] && prompt+=$'\n\n## Memory\n'"$memory"
  [[ -n "$context"      ]] && prompt+=$'\n\n## Context\n'"$context"
  [[ -n "$ws_meta"      ]] && prompt+=$'\n\n## Workspace\n'"$ws_meta"
  [[ -n "$ws_instr"     ]] && prompt+=$'\n\n## Workspace Instructions\n'"$ws_instr"
  [[ -n "$ws_mem"       ]] && prompt+=$'\n\n## Workspace Memory\n'"$ws_mem"
  [[ -n "$ws_ctx"       ]] && prompt+=$'\n\n## Workspace Context\n'"$ws_ctx"
  [[ -n "$ds_content"   ]] && prompt+=$'\n\n## Project\n'"$ds_content"
  [[ -n "$plan_content" ]] && prompt+=$'\n\n## Aktívny plán\n'"$plan_content"
  echo "$prompt"
}

_init_context_files
SYSTEM_PROMPT=$(_build_system_prompt)

LAST_PROMPT_TOKENS=0
LAST_COMPLETION_TOKENS=0
SESSION_DELEGATIONS=0

# ── helpers ───────────────────────────────────────────────────────────────────

estimate_tokens() {
  local s="$1"
  echo $(( ${#s} / 4 ))
}

# One-time migration from history.txt → history.json
migrate_history() {
  local txt="$HOME/.ai-os/sessions/history.txt"
  [[ -f "$txt" && ! -f "$HIST_FILE" ]] || return 0
  local arr='[]' line content
  while IFS= read -r line; do
    if [[ "$line" = "USER: "* ]]; then
      content="${line#USER: }"
      arr=$(jq -n --argjson h "$arr" --arg c "$content" '$h + [{"role":"user","content":$c}]')
    elif [[ "$line" = "ASSISTANT: "* ]]; then
      content="${line#ASSISTANT: }"
      arr=$(jq -n --argjson h "$arr" --arg c "$content" '$h + [{"role":"assistant","content":$c}]')
    fi
  done < "$txt"
  echo "$arr" > "$HIST_FILE"
}

# Compress oldest half of turns into a summary; returns new history JSON
compress_history() {
  local history_json="$1"
  local non_summary total half old_turns old_text sum_content sum_msgs summary
  local prev_summarized new_count recent

  non_summary=$(jq '[.[] | select(.role != "summary")]' <<< "$history_json")
  total=$(jq 'length' <<< "$non_summary")
  half=$(( total / 2 ))
  [[ $half -lt 2 ]] && { echo "$history_json"; return; }

  old_turns=$(jq --argjson n "$half" '.[:$n]' <<< "$non_summary")
  old_text=$(jq -r '.[] | "\(.role | ascii_upcase): \(.content)"' <<< "$old_turns")

  sum_content=$(printf 'Summarize the following conversation into one concise paragraph. Preserve all key facts, decisions, code snippets, user preferences, and important context. Output only the summary text with no preamble, labels, or explanation.\n\n%s' "$old_text")
  sum_msgs=$(jq -n --arg c "$sum_content" '[{"role":"user","content":$c}]')

  summary=$(ask "$sum_msgs" 2>/dev/null) || { echo "$history_json"; return; }
  [[ -z "$summary" ]] && { echo "$history_json"; return; }

  prev_summarized=$(jq '[.[] | select(.role=="summary") | .summarized_turns // 0] | add // 0' <<< "$history_json")
  new_count=$(( prev_summarized + half ))
  recent=$(jq --argjson n "$half" '.[$n:]' <<< "$non_summary")

  jq -n \
    --arg s "$summary" \
    --argjson n "$new_count" \
    --argjson r "$recent" \
    '[{"role":"summary","content":$s,"summarized_turns":$n}] + $r'
}

# ── API call ──────────────────────────────────────────────────────────────────

# ask MESSAGES [stream=false]
# stream=false (default): returns content via stdout — use with $()
# stream=true: streams tokens directly to stdout, saves result to $AI_TMP/last_stream.txt — call without $()
ask() {
  local messages="$1" stream="${2:-false}" tools="${3:-}"
  local all_messages payload
  all_messages=$(jq -n \
    --arg    system "$SYSTEM_PROMPT" \
    --argjson msgs   "$messages" \
    '[{"role":"system","content":$system}] + $msgs')
  if [[ -n "$tools" ]]; then
    payload=$(jq -n \
      --arg    model   "$MODEL_NAME" \
      --argjson msgs   "$all_messages" \
      --argjson temp   "$TEMPERATURE" \
      --argjson stream "$stream" \
      --argjson tools  "$tools" \
      '{"model":$model,"messages":$msgs,"temperature":$temp,"stream":$stream,"tools":$tools,"tool_choice":"auto"}')
  else
    payload=$(jq -n \
      --arg    model   "$MODEL_NAME" \
      --argjson msgs   "$all_messages" \
      --argjson temp   "$TEMPERATURE" \
      --argjson stream "$stream" \
      '{"model":$model,"messages":$msgs,"temperature":$temp,"stream":$stream}')
  fi

  if [[ "$stream" == true ]]; then
    local full_response="" is_sse=false raw_buf="" sse_line chunk token
    while IFS= read -r sse_line; do
      if [[ "$is_sse" == false && "$sse_line" != data:* && -n "$sse_line" ]]; then
        raw_buf+="${sse_line}"$'\n'
      fi
      [[ "$sse_line" = "data: [DONE]" ]] && break
      [[ "$sse_line" = data:* ]] || continue
      is_sse=true
      chunk="${sse_line#data: }"
      token=$(jq -r '.choices[0].delta.content // empty' <<< "$chunk" 2>/dev/null) || continue
      [[ -n "$token" ]] && printf '%s' "$token" && full_response+="$token"
    done < <(curl -sN --no-buffer "$ENDPOINT" \
      -H "Content-Type: application/json" \
      --config <(printf 'header = "Authorization: Bearer %s"\n' "$API_KEY") \
      -d "$payload" || true)

    # Fallback: non-SSE response (mock, error, or older API)
    if [[ "$is_sse" == false && -n "$raw_buf" ]]; then
      printf '%s' "$raw_buf" > "$AI_TMP/last_output.json"
      local fb
      fb=$(jq -r '.choices[0].message.content // empty' "$AI_TMP/last_output.json" 2>/dev/null)
      if [[ -n "$fb" ]]; then
        printf '%s' "$fb"
        full_response="$fb"
      else
        LAST_PROMPT_TOKENS=0; LAST_COMPLETION_TOKENS=0
        return 1
      fi
    fi

    printf '\n'
    printf '%s' "$full_response" > "$AI_TMP/last_stream.txt"
    jq -n --arg c "$full_response" '{"choices":[{"message":{"content":$c}}]}' > "$AI_TMP/last_output.json"
    LAST_PROMPT_TOKENS=0
    LAST_COMPLETION_TOKENS="${#full_response}"
  else
    local response
    response=$(curl -s "$ENDPOINT" \
      -H "Content-Type: application/json" \
      --config <(printf 'header = "Authorization: Bearer %s"\n' "$API_KEY") \
      -d "$payload")
    echo "$response" > "$AI_TMP/last_output.json"
    LAST_PROMPT_TOKENS=$(jq -r '.usage.prompt_tokens // 0' "$AI_TMP/last_output.json")
    LAST_COMPLETION_TOKENS=$(jq -r '.usage.completion_tokens // 0' "$AI_TMP/last_output.json")
    jq -r '.choices[0].message.content // empty' "$AI_TMP/last_output.json"
  fi
}

# Pro→Flash agentic tool-call loop (only called when MODEL=pro)
run_agentic() {
  local messages="$1"
  local max_delegations=5 delegation_count=0
  local orig_model="$MODEL" orig_model_name="$MODEL_NAME"

  while [[ $delegation_count -le $max_delegations ]]; do
    # Animated [pro...] — progressive dimming effect
    printf "${_C_DIM}[pro...]${_C_RESET}" >&2
    _start_spinner
    ask "$messages" false "$PRO_TOOLS" >/dev/null
    _stop_spinner
    # Clear the [pro...] line after completion
    printf '\r\033[K' >&2
    local finish_reason
    finish_reason=$(jq -r '.choices[0].finish_reason // "stop"' < "$AI_TMP/last_output.json")

    if [[ "$finish_reason" != "tool_calls" ]]; then
      local final_content
      final_content=$(jq -r '.choices[0].message.content // empty' < "$AI_TMP/last_output.json")
      _print_response "$final_content"
      printf '%s' "$final_content" > "$AI_TMP/last_stream.txt"
      SESSION_DELEGATIONS=$((SESSION_DELEGATIONS + delegation_count))
      return 0
    fi

    local tool_calls_json assistant_msg
    tool_calls_json=$(jq -c '.choices[0].message.tool_calls // []' < "$AI_TMP/last_output.json")
    assistant_msg=$(jq -c '.choices[0].message' < "$AI_TMP/last_output.json")
    messages=$(jq -n --argjson h "$messages" --argjson m "$assistant_msg" '$h + [$m]')

    local n_tools tool_idx
    n_tools=$(jq 'length' <<< "$tool_calls_json")
    for ((tool_idx = 0; tool_idx < n_tools; tool_idx++)); do
      local call_id func_name func_args_json flash_prompt flash_result flash_reason
      call_id=$(jq -r ".[$tool_idx].id" <<< "$tool_calls_json")
      func_name=$(jq -r ".[$tool_idx].function.name" <<< "$tool_calls_json")
      func_args_json=$(jq -r ".[$tool_idx].function.arguments" <<< "$tool_calls_json")

      if [[ "$func_name" == "delegate_to_flash" ]]; then
        flash_prompt=$(jq -r '.prompt // empty' <<< "$func_args_json")
        flash_reason=$(jq -r '.reason // ""' <<< "$func_args_json")

        if [[ -z "$flash_prompt" ]]; then
          flash_result="Error: delegate_to_flash called with empty prompt"
        elif [[ ${#flash_prompt} -gt 10000 ]]; then
          flash_result="Error: delegated prompt too large (max 10000 chars)"
        else
          [[ -n "$flash_reason" ]] \
            && printf "${_C_DIM}[→ flash: %s]${_C_RESET}\n" "$flash_reason" >&2 \
            || printf "${_C_DIM}[→ flash]${_C_RESET}\n" >&2
          MODEL="flash" MODEL_NAME="deepseek-v4-flash"
          local flash_messages
          flash_messages=$(jq -n --arg c "$flash_prompt" '[{"role":"user","content":$c}]')
          _start_spinner
          ask "$flash_messages" true
          _stop_spinner
          flash_result=$(< "$AI_TMP/last_stream.txt")
          MODEL="$orig_model" MODEL_NAME="$orig_model_name"
          printf "${_C_DIM}[← pro]${_C_RESET}\n" >&2
          delegation_count=$((delegation_count + 1))
        fi
      else
        flash_result=$(_handle_tool_call "$func_name" "$func_args_json")
      fi

      messages=$(jq -n \
        --argjson h "$messages" \
        --arg id      "$call_id" \
        --arg content "$flash_result" \
        '$h + [{"role":"tool","tool_call_id":$id,"content":$content}]')
    done
  done

  printf "${_C_DIM}[pro: concluding...]${_C_RESET}\n" >&2
  _start_spinner
  ask "$messages" false >/dev/null
  _stop_spinner
  local final_content
  final_content=$(jq -r '.choices[0].message.content // empty' < "$AI_TMP/last_output.json")
  _print_response "$final_content"
  printf '%s' "$final_content" > "$AI_TMP/last_stream.txt"
}

# ANSI color constants — empty when stderr is not a TTY (pipes, tests, NO_COLOR)
if [[ -t 2 && -z "${NO_COLOR:-}" ]]; then
  _C_RESET='\033[0m'
  _C_PATH='\033[36m'     # cyan     — paths, files, diff @@ headers
  _C_CMD='\033[38;5;117m' # light blue — shell commands (was yellow)
  _C_OK='\033[32m'       # green    — [auto], [safe], success messages
  _C_ERR='\033[38;5;208m' # orange   — errors, [exit N], diff deletions (was red)
  _C_DIM='\033[2m'       # dim      — [pro...], [→ flash:], meta prefixes
  _C_BOLD='\033[1m'      # bold     — confirmation prompts
  _C_BG_ADD='\033[48;5;22;97m' # dark green bg + white text — diff added lines
  _C_BG_DEL='\033[48;5;52m'   # wine-red bg — diff removed lines
  _C_BG_USER='\033[48;5;236m' # dark gray bg — user input in history
else
  _C_RESET='' _C_PATH='' _C_CMD='' _C_OK='' _C_ERR='' _C_DIM='' _C_BOLD=''
  _C_BG_ADD='' _C_BG_DEL='' _C_BG_USER=''
fi

# no-op stubs — overridden once the interactive session starts
_stop_spinner()      { :; }
_start_spinner()     { :; }
_stop_esc_monitor()  { :; }
_start_esc_monitor() { :; }
_colorize_diff()     { :; }

# Interactive option selector: shows options with arrow-key navigation, Enter to confirm.
# Usage: _select_option "Prompt text?" "Áno" "Nie" ["Tretia možnosť" ...]
# Returns selected option text via stdout. Falls back to simple read if /dev/tty unavailable.
_select_option() {
  local _so_prompt="$1"
  shift
  local _so_options=("$@")
  local _so_selected=0
  local _so_key _so_i

  # Fallback if no TTY — return last option (typically "Nie" or the safest default)
  if [[ ! -t 2 ]]; then
    printf '%s\n' "${_so_options[-1]}"
    return
  fi

  # Save terminal state
  local _so_old_stty
  _so_old_stty=$(stty -g 2>/dev/null || echo "")
  stty -echo -icanon 2>/dev/null || true

  # Hide cursor
  printf '\e[?25l' >&2

  _render_options() {
    local _so_i
    printf '%s ' "$_so_prompt" >&2
    for _so_i in "${!_so_options[@]}"; do
      if [[ "$_so_i" -eq "$_so_selected" ]]; then
        printf '\033[7m%s\033[0m' "${_so_options[$_so_i]}" >&2
      else
        printf '%s' "${_so_options[$_so_i]}" >&2
      fi
      if [[ "$_so_i" -lt $((${#_so_options[@]} - 1)) ]]; then
        printf '  ' >&2
      fi
    done
  }

  _render_options

  while true; do
    IFS= read -r -s -n 1 _so_key </dev/tty 2>/dev/null || _so_key=""
    case "$_so_key" in
      $'\e')
        # Arrow key sequence: ESC [ A/B/C/D
        IFS= read -r -s -n 1 -t 0.05 _so_key </dev/tty 2>/dev/null || continue
        if [[ "$_so_key" == '[' ]]; then
          IFS= read -r -s -n 1 -t 0.05 _so_key </dev/tty 2>/dev/null || continue
          case "$_so_key" in
            'C'|'B')  # Right or Down → next option
              _so_selected=$(( (_so_selected + 1) % ${#_so_options[@]} ))
              ;;
            'D'|'A')  # Left or Up → previous option
              _so_selected=$(( (_so_selected - 1 + ${#_so_options[@]}) % ${#_so_options[@]} ))
              ;;
          esac
        fi
        # Redraw
        printf '\r\033[K' >&2
        _render_options
        ;;
      '')
        # Enter key
        printf '\n' >&2
        break
        ;;
    esac
  done

  # Restore terminal state
  printf '\e[?25h' >&2
  if [[ -n "$_so_old_stty" ]]; then
    stty "$_so_old_stty" 2>/dev/null || true
  fi

  printf '%s' "${_so_options[$_so_selected]}"
}

SHELL_AUTO_APPROVE=""  # "" = off | "safe" = auto for read-only | "on" = always auto

# Returns 0 if command is read-only / non-destructive, 1 otherwise.
_is_safe_op() {
  local _c="$1"
  local _safe=(
    "cat " "ls" "ls " "find " "echo " "pwd" "which " "file " "stat "
    "head " "tail " "wc " "tree" "tree " "grep " "rg " "ag "
    "git status" "git log" "git diff" "git branch" "git show"
    "type " "basename " "dirname " "printf " "date" "du " "df "
  )
  for _p in "${_safe[@]}"; do
    [[ "$_c" == "$_p"* || "$_c" == "${_p% }" ]] && return 0
  done
  return 1
}

# _exec_shell_tool CMD [REASON] — shows command, asks user confirmation, executes
# Respects SHELL_AUTO_APPROVE. Safe default (no) when /dev/tty unavailable.
_exec_shell_tool() {
  local _cmd="$1" _reason="${2:-}"
  _stop_spinner

  if [[ "$SHELL_AUTO_APPROVE" == "on" ]]; then
    printf "\n${_C_OK}[auto]${_C_RESET} ${_C_CMD}%s${_C_RESET}\n" "$_cmd" >&2
    bash -c "$_cmd" 2>&1 || printf "${_C_ERR}[exit %s]${_C_RESET}\n" "$?"
    return
  fi

  if [[ "$SHELL_AUTO_APPROVE" == "safe" ]] && _is_safe_op "$_cmd"; then
    printf "\n${_C_OK}[safe]${_C_RESET} ${_C_CMD}%s${_C_RESET}\n" "$_cmd" >&2
    bash -c "$_cmd" 2>&1 || printf "${_C_ERR}[exit %s]${_C_RESET}\n" "$?"
    return
  fi

  _stop_esc_monitor
  [[ -n "$_reason" ]] \
    && printf "\n[shell] ${_C_CMD}%s${_C_RESET}  # %s\n" "$_cmd" "$_reason" >&2 \
    || printf "\n[shell] ${_C_CMD}%s${_C_RESET}\n" "$_cmd" >&2
  local _so_result
  _so_result=$(_select_option "Spustiť?" "Áno" "Nie" "Vždy Áno (táto session)")
  if [[ "$_so_result" == "Áno" ]]; then
    bash -c "$_cmd" 2>&1 || printf "${_C_ERR}[exit %s]${_C_RESET}\n" "$?"
  elif [[ "$_so_result" == "Vždy Áno (táto session)" ]]; then
    SHELL_AUTO_APPROVE="on"
    printf "\n${_C_OK}[auto: ON]${_C_RESET} ${_C_CMD}%s${_C_RESET}\n" "$_cmd" >&2
    bash -c "$_cmd" 2>&1 || printf "${_C_ERR}[exit %s]${_C_RESET}\n" "$?"
  else
    printf '[zrušené užívateľom]'
  fi
}

# ── agent tool implementations ────────────────────────────────────────────────

_tool_read_file() {
  local _args="$1"
  local _path _offset _limit
  _path=$(jq -r '.path // empty' <<< "$_args")
  _offset=$(jq -r '.offset // 1' <<< "$_args")
  _limit=$(jq -r '.limit // 200' <<< "$_args")
  [[ -z "$_path" ]] && printf 'Error: path required' && return
  [[ ! -f "$_path" ]] && printf 'Error: file not found: %s' "$_path" && return
  local _end=$(( _offset + _limit - 1 ))
  sed -n "${_offset},${_end}p" "$_path" 2>&1
}

_tool_write_file() {
  local _args="$1"
  local _path _content
  _path=$(jq -r '.path // empty' <<< "$_args")
  _content=$(jq -r '.content // empty' <<< "$_args")
  [[ -z "$_path" ]] && printf 'Error: path required' && return
  _stop_spinner
  _stop_esc_monitor

  # Show diff before asking — use mktemp (bash 3.2 compat, no process substitution)
  local _tmp_wf
  _tmp_wf=$(mktemp "$AI_TMP/write_diff_XXXXXX")
  printf '%s' "$_content" > "$_tmp_wf"
  if [[ -f "$_path" ]]; then
    local _diff_out
    _diff_out=$(diff -u "$_path" "$_tmp_wf" 2>/dev/null | head -80)
    if [[ -n "$_diff_out" ]]; then
      printf '\n' >&2
      printf '%s\n' "$_diff_out" | _colorize_diff
    else
      printf "${_C_DIM}(žiadne zmeny oproti súčasnému obsahu)${_C_RESET}\n" >&2
    fi
  else
    printf "${_C_DIM}(nový súbor — %d B)${_C_RESET}\n" "${#_content}" >&2
  fi
  rm -f "$_tmp_wf"

  printf "\n[write_file] ${_C_PATH}%s${_C_RESET}\n" "$_path" >&2
  local _so_result
  _so_result=$(_select_option "Zapísať?" "Áno" "Nie" "Áno a nezobrazovať diff nabudúce")
  if [[ "$_so_result" == "Áno" ]]; then
    printf '%s' "$_content" > "$_path" 2>&1 \
      && printf "${_C_OK}OK: %s (%d bajtov)${_C_RESET}" "$_path" "${#_content}" \
      || printf "${_C_ERR}Error: zápis zlyhal${_C_RESET}"
  elif [[ "$_so_result" == "Áno a nezobrazovať diff nabudúce" ]]; then
    printf '%s' "$_content" > "$_path" 2>&1 \
      && printf "${_C_OK}OK: %s (%d bajtov)${_C_RESET}" "$_path" "${#_content}" \
      || printf "${_C_ERR}Error: zápis zlyhal${_C_RESET}"
    # Set project-level flag to skip diff preview next time
    printf '%s' "$_path" > "$HOME/.ai-os/write_no_diff" 2>/dev/null || true
  else
    printf '[zrušené užívateľom]'
  fi
}

_tool_grep_search() {
  local _args="$1"
  local _pattern _path _opts _safe_opts
  _pattern=$(jq -r '.pattern // empty' <<< "$_args")
  _path=$(jq -r '.path // "."' <<< "$_args")
  _opts=$(jq -r '.options // ""' <<< "$_args")
  [[ -z "$_pattern" ]] && printf 'Error: pattern required' && return
  # Sanitize options: only allow safe flags (-i, -l, -w, -r, -n, -I, --exclude-dir=, --include=)
  _safe_opts=""
  for _o in $_opts; do
    case "$_o" in
      -i|-l|-w|-r|-n|-I) _safe_opts+=" $_o" ;;
      --exclude-dir=*)   _safe_opts+=" $_o" ;;
      --include=*)       _safe_opts+=" $_o" ;;
      *) : ;; # silently drop unsafe flags
    esac
  done
  # shellcheck disable=SC2086
  grep -rn ${_safe_opts} "$_pattern" "$_path" 2>&1 | head -100
}

_tool_git_info() {
  local _args="$1"
  local _type
  _type=$(jq -r '.type // "status"' <<< "$_args")
  case "$_type" in
    status) git status --short 2>&1 ;;
    diff)   git diff HEAD 2>&1 | head -300 ;;
    log)    git log --oneline -20 2>&1 ;;
    branch) git branch --show-current 2>&1 ;;
    *)      printf 'Error: neznámy typ git_info' ;;
  esac
}

_tool_save_plan() {
  local _args="$1"
  local _content _name _path _ts
  _content=$(jq -r '.content // empty' <<< "$_args")
  _name=$(jq -r '.name // "plan"' <<< "$_args")
  [[ -z "$_content" ]] && printf 'Error: content required' && return
  _name=$(printf '%s' "$_name" | tr -cd 'a-zA-Z0-9_-' | cut -c1-50)
  [[ -z "$_name" ]] && _name="plan"
  mkdir -p "$HOME/.ai-os/plans"
  # Save with timestamp for version tracking
  _ts=$(date '+%Y%m%d_%H%M%S')
  _path="$HOME/.ai-os/plans/${_name}-${_ts}.md"
  printf '%s\n' "$_content" > "$_path" \
    && printf '%s' "$_path" > "$HOME/.ai-os/current-plan" \
    && printf 'Plán uložený: %s' "$_path" \
    || printf 'Error: zápis plánu zlyhal'
}

_colorize_diff() {
  while IFS= read -r _dl; do
    case "$_dl" in
      '@@'*)         printf "${_C_PATH}%s${_C_RESET}\n"  "$_dl" ;;
      '+++'*|'---'*) printf "${_C_DIM}%s${_C_RESET}\n"   "$_dl" ;;
      '+'*)          printf "${_C_BG_ADD}%s${_C_RESET}\n"  "$_dl" ;;
      '-'*)          printf "${_C_BG_DEL}%s${_C_RESET}\n"  "$_dl" ;;
      *)             printf '%s\n' "$_dl" ;;
    esac
  done >&2
}

# _handle_tool_call FUNC_NAME FUNC_ARGS — dispatcher for all agent tools.
# Prints result to stdout. Does NOT handle delegate_to_flash (run_agentic only).
_print_response() { printf '%s\n' "$1"; }

_handle_tool_call() {
  local _fn="$1" _fa="$2" _result=""
  case "$_fn" in
    run_shell)
      local _sc _sr
      _sc=$(jq -r '.command // empty' <<< "$_fa")
      _sr=$(jq -r '.reason // ""' <<< "$_fa")
      if [[ -z "$_sc" ]]; then
        _result="Error: run_shell called with empty command"
      else
        _result=$(_exec_shell_tool "$_sc" "$_sr")
      fi
      ;;
    read_file)    _result=$(_tool_read_file "$_fa") ;;
    write_file)   _result=$(_tool_write_file "$_fa") ;;
    grep_search)  _result=$(_tool_grep_search "$_fa") ;;
    git_info)     _result=$(_tool_git_info "$_fa") ;;
    save_plan)    _result=$(_tool_save_plan "$_fa") ;;
    *)            _result="Error: unknown tool '${_fn}'" ;;
  esac
  printf '%s' "$_result"
}

# run_interactive_flash MESSAGES — blocking tool-call loop for flash interactive mode.
# Handles all FLASH_INTERACTIVE_TOOLS; prints final content to stdout.
run_interactive_flash() {
  local _msgs="$1"
  local _max_iter=10 _iter=0 _finish _content
  local _tool_calls _assistant_msg _n_tools _tool_idx
  local _call_id _func_name _func_args _tool_result

  while [[ $_iter -lt $_max_iter ]]; do
    _start_spinner
    ask "$_msgs" false "$FLASH_INTERACTIVE_TOOLS" >/dev/null
    _stop_spinner
    _finish=$(jq -r '.choices[0].finish_reason // "stop"' < "$AI_TMP/last_output.json")

    if [[ "$_finish" != "tool_calls" ]]; then
      _content=$(jq -r '.choices[0].message.content // empty' < "$AI_TMP/last_output.json")
      _print_response "$_content"
      printf '%s' "$_content" > "$AI_TMP/last_stream.txt"
      return 0
    fi

    _tool_calls=$(jq -c '.choices[0].message.tool_calls // []' < "$AI_TMP/last_output.json")
    _assistant_msg=$(jq -c '.choices[0].message' < "$AI_TMP/last_output.json")
    _msgs=$(jq -n --argjson h "$_msgs" --argjson m "$_assistant_msg" '$h + [$m]')

    _n_tools=$(jq 'length' <<< "$_tool_calls")
    for ((_tool_idx = 0; _tool_idx < _n_tools; _tool_idx++)); do
      _call_id=$(jq -r ".[$_tool_idx].id" <<< "$_tool_calls")
      _func_name=$(jq -r ".[$_tool_idx].function.name" <<< "$_tool_calls")
      _func_args=$(jq -r ".[$_tool_idx].function.arguments" <<< "$_tool_calls")
      _tool_result=$(_handle_tool_call "$_func_name" "$_func_args")

      _msgs=$(jq -n \
        --argjson h "$_msgs" \
        --arg id      "$_call_id" \
        --arg content "$_tool_result" \
        '$h + [{"role":"tool","tool_call_id":$id,"content":$content}]')
    done
    _iter=$((_iter + 1))
  done

  # Max iterations reached — final call without tools
  _stop_spinner
  ask "$_msgs" false >/dev/null
  _content=$(jq -r '.choices[0].message.content // empty' < "$AI_TMP/last_output.json")
  _print_response "$_content"
  printf '%s' "$_content" > "$AI_TMP/last_stream.txt"
}

# ── session helpers ───────────────────────────────────────────────────────────

# Sets global LOADED_MESSAGES and may modify global SYSTEM_PROMPT.
# Must be called as a plain command, not via $(...), to preserve side-effects.
LOADED_MESSAGES='[]'
load_session() {
  migrate_history
  if [[ ! -f "$HIST_FILE" ]]; then
    LOADED_MESSAGES='[]'
    return
  fi

  local hist tokens summary_content
  hist=$(< "$HIST_FILE")
  tokens=$(estimate_tokens "$hist")

  if [[ $tokens -gt $CONTEXT_LIMIT ]]; then
    local compressed
    compressed=$(compress_history "$hist")
    echo "$compressed" > "$HIST_FILE"
    hist="$compressed"
  fi

  summary_content=$(jq -r '[.[] | select(.role=="summary") | .content] | join("\n\n")' <<< "$hist")
  if [[ -n "$summary_content" ]]; then
    SYSTEM_PROMPT="${SYSTEM_PROMPT}

[Zhrnutie predchádzajúcej konverzácie]
${summary_content}"
  fi

  LOADED_MESSAGES=$(jq '[.[] | select(.role != "summary")]' <<< "$hist")
}

save_session() {
  local prompt="$1" output="$2"
  mkdir -p "$(dirname "$HIST_FILE")"
  local current='[]'
  [[ -f "$HIST_FILE" ]] && current=$(< "$HIST_FILE")
  jq -n \
    --argjson h "$current" \
    --arg p "$prompt" \
    --arg o "$output" \
    '$h + [{"role":"user","content":$p},{"role":"assistant","content":$o}]' \
    > "$HIST_FILE"
}

# ── interactive mode ──────────────────────────────────────────────────────────

if [[ "$MODE" = "interactive" ]]; then
  CONV='[]'
  PLAN_MODE=false
  SESSION_DELEGATIONS=0

  HISTFILE="$HOME/.ai-os/sessions/interactive_history"
  HISTSIZE=500
  HISTFILESIZE=500
  mkdir -p "$(dirname "$HISTFILE")"
  history -r "$HISTFILE" 2>/dev/null || true

  # Warp OSC 133 shell integration
  WARP=""
  [[ "${TERM_PROGRAM:-}" == "WarpTerminal" ]] && WARP=true
  warp_seq() { [[ -n "$WARP" ]] && printf '\033]133;%s\007' "$1" || true; }

  # ESC interrupt helpers
  _ESC_PID=""
  _start_esc_monitor() {
    local _ppid=$$
    (
      { exec </dev/tty; } 2>/dev/null || exit 0
      _k=""
      while kill -0 "$_ppid" 2>/dev/null; do
        _k=""
        IFS= read -r -s -t 1 -n 1 _k || true
        [[ "$_k" == $'\033' ]] && kill -USR1 "$_ppid" 2>/dev/null && break
      done
    ) &
    _ESC_PID=$!
    disown "$_ESC_PID" 2>/dev/null || true
  }
  _stop_esc_monitor() {
    if [[ -n "$_ESC_PID" ]]; then
      kill "$_ESC_PID" 2>/dev/null || true
      _ESC_PID=""
    fi
    # read -r -s in the subshell disables terminal echo; restore it on kill
    stty echo 2>/dev/null || true
  }

  _SPINNER_PID=""
  _start_spinner() {
    (
      local frames=('|' '/' '-' '\')
      local i=0
      while true; do
        printf '%s\b' "${frames[$i]}" >&2
        i=$(( (i+1) % 4 ))
        sleep 0.12
      done
    ) &
    _SPINNER_PID=$!
    disown "$_SPINNER_PID" 2>/dev/null || true
  }
  _stop_spinner() {
    if [[ -n "$_SPINNER_PID" ]]; then
      kill "$_SPINNER_PID" 2>/dev/null || true
      _SPINNER_PID=""
      printf ' \b' >&2  # overwrite last spinner char, cursor stays in place
    fi
  }

  _print_response() { printf '%s\n' "$1" | sed "s/^/□ /"; }

  SHELL_AUTO_APPROVE=""  # session-scoped; reset on each interactive session

  # Inject lightweight runtime state before each user message.
  _runtime_context() {
    local _ctx="[Runtime Context]"$'\n'"CWD: $PWD"
    if git rev-parse --git-dir &>/dev/null 2>&1; then
      local _branch _changes
      _branch=$(git branch --show-current 2>/dev/null || printf 'detached')
      _changes=$(git status --porcelain 2>/dev/null | wc -l | tr -d ' ')
      _ctx+=$'\n'"Git: branch=${_branch}"
      [[ "$_changes" -gt 0 ]] && _ctx+=", ${_changes} zmenených" || _ctx+=", čistý"
    fi
    if [[ -f "$HOME/.ai-os/current-plan" ]]; then
      local _rcp
      _rcp=$(< "$HOME/.ai-os/current-plan"); _rcp="${_rcp%$'\n'}"
      [[ -f "$_rcp" ]] && _ctx+=$'\n'"Aktívny plán: $_rcp (read_file pre obsah)"
    fi
    printf '%s' "$_ctx"
  }

  # Tab completion for slash commands
  __ai_tab() {
    local cur="$READLINE_LINE"

    # /memory sub-command cycling
    if [[ "$cur" = "/memory" || "$cur" = "/memory " \
       || "$cur" = "/memory edit"* || "$cur" = "/memory add"* ]]; then
      local _mopts=("/memory edit " "/memory add ")
      local _mnext=0 _mi
      for _mi in "${!_mopts[@]}"; do
        local _mopt="${_mopts[$_mi]%' '}"
        if [[ "$cur" = "${_mopts[$_mi]}" || "$cur" = "$_mopt" ]]; then
          _mnext=$(( (_mi + 1) % ${#_mopts[@]} ))
          break
        fi
      done
      printf '\n  '
      for _mi in "${!_mopts[@]}"; do
        [[ "$_mi" -eq "$_mnext" ]] \
          && printf '\033[1;32m[%s]\033[0m  ' "${_mopts[$_mi]}" \
          || printf '%s  ' "${_mopts[$_mi]}"
      done
      printf '\n'
      READLINE_LINE="${_mopts[$_mnext]}"
      READLINE_POINT=${#READLINE_LINE}
      return
    fi

    # /project sub-command cycling: Tab cycles through sub-commands
    if [[ "$cur" = "/project" || "$cur" = "/project " \
       || "$cur" = "/project new"* || "$cur" = "/project list"* \
       || "$cur" = "/project set"* || "$cur" = "/project clear"* ]]; then
      local _popts=("/project new " "/project list" "/project set " "/project clear")
      local _pnext=0 _pi
      for _pi in "${!_popts[@]}"; do
        local _opt="${_popts[$_pi]%' '}"
        if [[ "$cur" = "${_popts[$_pi]}" || "$cur" = "$_opt" ]]; then
          _pnext=$(( (_pi + 1) % ${#_popts[@]} ))
          break
        fi
      done
      printf '\n  '
      for _pi in "${!_popts[@]}"; do
        [[ "$_pi" -eq "$_pnext" ]] \
          && printf '\033[1;32m[%s]\033[0m  ' "${_popts[$_pi]}" \
          || printf '%s  ' "${_popts[$_pi]}"
      done
      printf '\n'
      READLINE_LINE="${_popts[$_pnext]}"
      READLINE_POINT=${#READLINE_LINE}
      return
    fi

    # Standard slash command prefix completion
    [[ "$cur" != /* ]] && return
    local cmds=("/status" "/reset" "/compact" "/plan" "/plan save" "/plan load "
                 "/plan clear" "/plan show" "/batch " "/save " "/load "
                 "/model " "/memory" "/project" "/workspace" "/clear" "/help" "/exit")
    local matches=()
    for c in "${cmds[@]}"; do
      [[ "$c" = "$cur"* ]] && matches+=("$c")
    done
    if [[ ${#matches[@]} -eq 1 ]]; then
      READLINE_LINE="${matches[0]}"
      READLINE_POINT=${#READLINE_LINE}
    elif [[ ${#matches[@]} -gt 1 ]]; then
      printf '\n%s\n' "${matches[*]}"
      READLINE_LINE="$cur"
      READLINE_POINT=${#READLINE_LINE}
    fi
  }
  bind -x '"\t": __ai_tab' 2>/dev/null || true
  bind 'set enable-bracketed-paste on' 2>/dev/null || true

  trap '_stop_spinner; _stop_esc_monitor' EXIT

  echo "AI-OS  •  $MODEL  •  /help pre príkazy  •  Ctrl+C na ukončenie"
  echo "────────────────────────────────────────────────────────────────"
  trap 'true' INT  # not '' — readline needs non-SIG_IGN to install its SIGINT handler
  while true; do
    warp_seq A
    local_read_rc=0
    IFS= read -er -p $'\n> ' INPUT || local_read_rc=$?
    if [[ "$local_read_rc" -eq 130 ]]; then
      printf '\n'
      continue
    elif [[ "$local_read_rc" -ne 0 ]]; then
      break
    fi
    warp_seq C
    [[ "$INPUT" = "exit" || "$INPUT" = "quit" || -z "$INPUT" ]] && break

    history -s -- "$INPUT"

    # Shell passthrough — model is bypassed entirely, no tokens used
    if [[ "$INPUT" = "!"* ]]; then
      local_shell_cmd="${INPUT:1}"
      if [[ -n "$local_shell_cmd" ]]; then
        eval "$local_shell_cmd" || true
      fi
      warp_seq "D;0"
      continue
    fi

    local_skip_api=true
    if [[ "$INPUT" = /* ]]; then
      case "$INPUT" in
        /status)
          MSG_COUNT=$(jq 'length' <<< "$CONV")
          CONV_TOKENS=$(estimate_tokens "$CONV")
          MEM_SIZE=0
          [[ -f ~/.ai-os/memory.md ]] && MEM_SIZE=$(wc -c < ~/.ai-os/memory.md | tr -d ' ')
          printf 'model:              %s\ntemperature:        %s\nmessages:           %s\nestim. tokens:      %s\nprompt_tokens:      %s\ncompletion_tokens:  %s\nmemory:             %s B\ndelegations:        %s\n' \
            "$MODEL_NAME" "$TEMPERATURE" "$MSG_COUNT" "$CONV_TOKENS" "$LAST_PROMPT_TOKENS" "$LAST_COMPLETION_TOKENS" "$MEM_SIZE" "$SESSION_DELEGATIONS"
          ;;
        /reset)
          CONV='[]'
          echo "História konverzácie vymazaná."
          ;;
        /memory*)
          local_mem_sub="${INPUT#/memory}"
          local_mem_sub="${local_mem_sub# }"
          case "$local_mem_sub" in
            add\ *|add)
              local_mem_text="${local_mem_sub#add}"
              local_mem_text="${local_mem_text# }"
              if [[ -z "$local_mem_text" ]]; then
                echo "Použitie: /memory add <text>"
              else
                printf '\n%s\n' "$local_mem_text" >> ~/.ai-os/memory.md
                echo "Zapísané do memory.md."
              fi
              ;;
            edit*)
              local_mem_key="${local_mem_sub#edit}"
              local_mem_key="${local_mem_key# }"
              # Build key→file map
              local_mem_ws=""
              [[ -f ~/.ai-os/workspace ]] && local_mem_ws=$(< ~/.ai-os/workspace) && local_mem_ws="${local_mem_ws%$'\n'}"
              local_mem_proj=""
              [[ -f ~/.ai-os/current-project ]] && local_mem_proj=$(< ~/.ai-os/current-project) && local_mem_proj="${local_mem_proj%$'\n'}"
              # Interactive pick if no key given
              if [[ -z "$local_mem_key" ]]; then
                printf 'Dostupné súbory:\n'
                printf '  instructions      ~/.ai-os/instructions.md\n'
                printf '  memory            ~/.ai-os/memory.md\n'
                printf '  context           ~/.ai-os/context.md\n'
                [[ -n "$local_mem_ws" ]] && printf '  ws                %s/ds.md\n' "$local_mem_ws"
                [[ -n "$local_mem_ws" ]] && printf '  ws-instructions   %s/memory/instructions.md\n' "$local_mem_ws"
                [[ -n "$local_mem_ws" ]] && printf '  ws-memory         %s/memory/memory.md\n' "$local_mem_ws"
                [[ -n "$local_mem_ws" ]] && printf '  ws-context        %s/memory/context.md\n' "$local_mem_ws"
                [[ -n "$local_mem_proj" ]] && printf '  proj              %s/ds.md\n' "$local_mem_proj"
                printf 'Kľúč: '
                IFS= read -r local_mem_key || local_mem_key=""
              fi
              case "$local_mem_key" in
                instructions) local_mem_edit_f=~/.ai-os/instructions.md ;;
                memory)       local_mem_edit_f=~/.ai-os/memory.md ;;
                context)      local_mem_edit_f=~/.ai-os/context.md ;;
                ws)           local_mem_edit_f="${local_mem_ws}/ds.md" ;;
                ws-instructions) local_mem_edit_f="${local_mem_ws}/memory/instructions.md" ;;
                ws-memory)    local_mem_edit_f="${local_mem_ws}/memory/memory.md" ;;
                ws-context)   local_mem_edit_f="${local_mem_ws}/memory/context.md" ;;
                proj)         local_mem_edit_f="${local_mem_proj}/ds.md" ;;
                *) echo "Neznámy kľúč '${local_mem_key}'. Použi: instructions|memory|context|ws|ws-instructions|ws-memory|ws-context|proj" ;;
              esac
              if [[ -n "${local_mem_edit_f:-}" ]]; then
